{
  "name": "vsc-pdf-studio",
  "displayName": "PDF Studio",
  "description": "Review, annotate, comment on, and navigate PDFs inside VS Code.",
  "version": "0.0.1",
  "publisher": "zee",
  "icon": "media/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:pdfAnnotator.editor"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "pdfAnnotator.editor",
        "displayName": "PDF Studio",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "sync:pdfjs": "cp node_modules/pdfjs-dist/build/pdf.min.js media/libs/pdf.min.js && cp node_modules/pdfjs-dist/build/pdf.worker.min.js media/libs/pdf.worker.min.js && cp node_modules/pdfjs-dist/web/pdf_viewer.js media/libs/pdf_viewer.js",
    "package": "vscode-vsce package",
    "pretest": "npm run compile",
    "test": "echo \"No tests configured yet\""
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.2",
    "pdfjs-dist": "^3.11.174",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
